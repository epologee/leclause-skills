#!/usr/bin/env bash
#
# marketplace-release: build a materialised release branch for Windows consumers.
#
# Runs on macOS (operator) and on Linux (GitHub Actions, .github/workflows/
# release-branch.yml). The normal publish path is the Action on every push to
# main; operators only invoke this by hand to debug or to publish outside the
# normal flow.
#
# main carries symlinks that share skills across plugins. Windows users cannot
# clone those cleanly, because Git for Windows defaults to core.symlinks=false
# (symlinks become text files) and Claude Code's install pipeline compounds
# that. This script builds a staging tree where `rsync -aL` has replaced every
# symlink with the real content, then force-pushes the tree as the `release`
# branch of origin. Consumers install via `@release` and get a symlink-free
# plugin cache.
#
# Usage:
#   bin/marketplace-release            Dry-run: build staging, show summary.
#   bin/marketplace-release --write    Build staging, force-push to release.
#
# Safeguards:
#   * Must run on main with a clean working tree. Other branches risk shipping
#     in-progress state.
#   * Builds in /tmp/leclause-release-build, never touches the repo's working
#     tree or index.
#   * Dry-run is default. --write is the explicit publish step.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

MODE="${1:---dry-run}"
BUILD=$(mktemp -d "${TMPDIR:-/tmp}/leclause-release-build.XXXXXX")
RELEASE_BRANCH="release"
REMOTE="origin"

# Clean up the staging dir on exit so the disk does not accumulate droppings.
trap 'rm -rf "$BUILD"' EXIT

current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" != "main" ]; then
  echo "ERROR: marketplace-release must run on main (currently on $current_branch)." >&2
  exit 1
fi

if [ -n "$(git status --short)" ]; then
  echo "ERROR: working tree has uncommitted changes. Commit or stash first." >&2
  git status --short >&2
  exit 1
fi

SOURCE_SHA=$(git rev-parse HEAD)

# Build staging with every symlink dereferenced to its target content.
rsync -aL \
  --exclude=.git \
  --exclude=.autonomous \
  --exclude=node_modules \
  --exclude='*.lock' \
  ./ "$BUILD/"

# Sanity check: no symlinks must remain in staging.
SYMLINK_COUNT=$(find "$BUILD" -type l 2>/dev/null | wc -l | tr -d ' ')
if [ "$SYMLINK_COUNT" -ne 0 ]; then
  echo "ERROR: $SYMLINK_COUNT symlinks remain in staging after rsync -aL." >&2
  find "$BUILD" -type l >&2
  exit 1
fi

FILES=$(find "$BUILD" -type f | wc -l | tr -d ' ')
echo "Staging:  $BUILD"
echo "Source:   main @ $SOURCE_SHA"
echo "Files:    $FILES"
echo "Symlinks: 0"

case "$MODE" in
  --dry-run)
    echo ""
    echo "Dry-run complete. To publish: $0 --write"
    ;;
  --write)
    ORIGIN_URL=$(git remote get-url "$REMOTE")
    (
      cd "$BUILD"
      git init -q -b "$RELEASE_BRANCH"
      git add -A
      git commit -q -m "Release snapshot from main @ $SOURCE_SHA"
      git remote add origin "$ORIGIN_URL"
      git push --force origin "HEAD:$RELEASE_BRANCH"
      echo ""
      echo "Pushed $RELEASE_BRANCH to $REMOTE."
      echo ""
      echo "Consumer install:"
      echo "  claude plugins marketplace add <owner>/<repo>@$RELEASE_BRANCH"
    )
    ;;
  --help|-h)
    echo "Usage: $0 {--dry-run|--write}"
    ;;
  *)
    echo "Usage: $0 {--dry-run|--write}" >&2
    exit 1
    ;;
esac
