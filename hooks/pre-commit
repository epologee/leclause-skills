#!/bin/sh
#
# Verify that every skill directory is mentioned in README.md.
# Prevents publishing a skill that visitors can't discover.
#
# Also enforces per-plugin version bumps via bin/plugin-versions --staged.
# Backstop for the dont-do-that Claude Code PreToolUse hook, which misses
# chained `git add && git commit` calls because staging happens after the
# PreToolUse hook fires. This git-level hook runs after staging, so it
# always sees the real staged diff.
#
# Setup: git config core.hooksPath hooks

readme="README.md"

if [ ! -f "$readme" ]; then
  echo "ERROR: README.md not found."
  exit 1
fi

missing=""

for skill_dir in packages/*/skills/*/; do
  [ -d "$skill_dir" ] || continue
  skill_name=$(basename "$skill_dir")
  if ! grep -qFw "$skill_name" "$readme"; then
    missing="$missing  - $skill_name\n"
  fi
done

if [ -n "$missing" ]; then
  echo "ERROR: Skills missing from README.md:"
  echo ""
  printf '%b' "$missing"
  echo ""
  echo "Add a description for each skill to README.md before committing."
  exit 1
fi

# Block symlinks anywhere in the repo. This repo is symlink-free so that
# Windows consumers can clone with core.symlinks=false and still get working
# files. A symlink in the index also means two paths point at the same
# content, which makes "which file am I editing?" ambiguous when plugins get
# updated. Shared check so hook and CI cannot drift.
if ! bin/check-no-symlinks; then
  exit 1
fi

# Block non-portable consumer-facing scripts under packages/*/bin/.
# These ship with the plugin and run on the consumer's machine via Claude Code's
# Bash tool. Claude Code already requires Node, and Python 3 is widely enough
# available that both are safe bets across macOS, Linux, and Windows. Anything
# else (shell, perl, ruby, python2, pwsh, dash) is a non-portable assumption:
# some Windows consumers will not have it, or it will route through a shell
# that cannot execute the script. Operator-only tooling lives under the repo-
# root bin/ and is free to use anything.
#
# Runs BEFORE plugin-versions so a rejected commit does not leave a bumped
# plugin.json in the working tree.
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
old_ifs=$IFS
IFS='
'
for staged_file in $staged_files; do
  case "$staged_file" in
    packages/*/bin/*)
      [ -f "$staged_file" ] || continue
      first_line=$(head -1 "$staged_file" 2>/dev/null)
      case "$first_line" in
        # Portable: Node, Python 3. Skip them.
        "#!/usr/bin/env node"*|"#!/usr/bin/env python3"*)
          ;;
        # Anything else that looks like a shebang is a non-portable interpreter.
        "#!"*)
          echo "ERROR: consumer-facing bin script uses a non-portable interpreter."
          echo "  File:    $staged_file"
          echo "  Shebang: $first_line"
          echo ""
          echo "Consumer-facing bin/ scripts must run on macOS, Linux, AND"
          echo "Windows without assuming which Bash tool routing the consumer"
          echo "chose. The only accepted shebangs are:"
          echo "  #!/usr/bin/env node"
          echo "  #!/usr/bin/env python3"
          echo ""
          echo "Port the script to one of those before committing. Operator-only"
          echo "scripts live under the repo-root bin/ and may use anything."
          exit 1
          ;;
      esac
      ;;
  esac
done
IFS=$old_ifs

plugin_versions_script="bin/plugin-versions"
if [ -x "$plugin_versions_script" ]; then
  PLUGIN_VERSIONS_GIT_CMD=$(ps -o args= -p $PPID 2>/dev/null || echo "git commit")
  export PLUGIN_VERSIONS_GIT_CMD
  if ! "$plugin_versions_script" --staged; then
    echo "ERROR: $plugin_versions_script --staged failed." >&2
    exit 1
  fi
fi

# After a commit on main that changed plugin content, nudge the operator to
# push. Main is the single install target for every OS now that the repo is
# symlink-free; Windows consumers get the update as soon as main moves.
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ "$current_branch" = "main" ]; then
  if git diff --cached --name-only --diff-filter=ACMR | grep -qE '^packages/'; then
    echo "" >&2
    echo "Push this to main so consumers (every OS) can pick up the update." >&2
  fi
fi
