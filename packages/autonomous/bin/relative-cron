#!/usr/bin/env node
// Calculates a cron expression that fires N minutes from now.
//
// For short intervals (<= 10 min), returns */N (close enough).
// For longer intervals, calculates the exact minute to fire at,
// because */20 means :00/:20/:40, not "in 20 minutes."
//
// Usage: relative-cron <minutes>
// Output: a 5-field cron expression on stdout
//
// Behaviour matches the legacy bash version bit-for-bit:
//   * short path: `*/N * * * *`
//   * long path: `(current_minute + N) % 60`, with a +1 nudge when N is a
//     multiple of 60 so the cron does not fire on the current minute.
//
// Ports to Node so Windows consumers running Claude Code via PowerShell
// get a working implementation without a POSIX shell dependency.

"use strict";

const args = process.argv.slice(2);

if (args.length !== 1) {
  process.stderr.write("Usage: relative-cron <minutes>\n");
  process.exit(1);
}

const input = args[0];

if (!/^[0-9]+$/.test(input)) {
  process.stderr.write("Usage: relative-cron <minutes> (must be positive integer)\n");
  process.exit(1);
}

const minutes = parseInt(input, 10);

if (minutes <= 0 || !Number.isSafeInteger(minutes)) {
  process.stderr.write("Usage: relative-cron <minutes> (must be positive integer)\n");
  process.exit(1);
}

if (minutes <= 10) {
  process.stdout.write(`*/${minutes} * * * *\n`);
  process.exit(0);
}

const currentMinute = new Date().getMinutes();
const fireAt = (minutes % 60 === 0)
  ? (currentMinute + 1) % 60
  : (currentMinute + minutes) % 60;

process.stdout.write(`${fireAt} * * * *\n`);
