#!/bin/bash
# packages/gitgit/skills/commit-discipline/git-hooks/prepare-commit-msg
#
# git-native prepare-commit-msg hook. Pre-fills the commit message file with
# a structured body template derived from the staged diff.
#
# Arguments supplied by git:
#   $1  commit-msg file path
#   $2  commit source: "message", "template", "merge", "squash", "commit", or
#       empty string (normal interactive commit)
#   $3  commit SHA (only when source is "commit", i.e. --amend)
#
# Behaviour by source:
#   merge, squash  -> do nothing (git already filled the message)
#   commit         -> do nothing (--amend or programmatic; author owns msg)
#   message        -> do nothing (operator passed -m; they have their message)
#   template       -> do nothing (commit.template wins)
#   (empty)        -> pre-fill with the schema template (normal interactive)
#
# At install time, /gitgit:install-hooks substitutes __PLUGIN_INSTALL_PATH__
# with the absolute path of the active gitgit plugin install. The shared
# classification library is sourced from there.

set -uo pipefail

PLUGIN_PATH="__PLUGIN_INSTALL_PATH__"
CLASSIFY_LIB="$PLUGIN_PATH/hooks/lib/layer-classify.sh"

msg_file="${1:-}"
commit_source="${2:-}"
# $3 is SHA for amend; unused here.

# ---------------------------------------------------------------------------
# Guard: only act on normal interactive commits
# ---------------------------------------------------------------------------

case "$commit_source" in
  merge|squash|commit|message|template)
    exit 0
    ;;
esac

# Also exit if msg_file is missing.
if [[ -z "$msg_file" ]] || [[ ! -f "$msg_file" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Source the classification library
# ---------------------------------------------------------------------------

if [[ ! -f "$CLASSIFY_LIB" ]]; then
  # Library not found; silently skip template-fill so the commit still works.
  exit 0
fi

# shellcheck disable=SC1090
. "$CLASSIFY_LIB"

# ---------------------------------------------------------------------------
# Classify staged diff
# ---------------------------------------------------------------------------

staged_paths=$(git diff --cached --name-only 2>/dev/null || true)

layer_summary=$(printf '%s\n' "$staged_paths" | classify_diff)
slice_suggestion=$(suggest_slice "$layer_summary")
tests_suggestion=$(printf '%s\n' "$staged_paths" | suggest_tests)

# ---------------------------------------------------------------------------
# Build the template block
# ---------------------------------------------------------------------------

template_block=""

template_block="${template_block}
# WHY: explain the change in two short sentences below this comment.
# Replace this whole comment with prose, or delete the body for a trivial commit.
#
# gitgit commit body schema (delete the lines you do not need):
# Tests: <comma-separated spec paths that ran green>
# Slice: <suggested-classification>
# Red-then-green: <yes | n/a (rationale)>
# Resolves: <issue url, or omit>
# Cucumber: <applicable | n/a (rationale), or omit>
#
# Auto-detected from your staged diff:
#   Layers: ${layer_summary}
#   Suggested Slice: ${slice_suggestion}"

if [[ -n "$tests_suggestion" ]]; then
  template_block="${template_block}
#   Suggested Tests: ${tests_suggestion}"
else
  template_block="${template_block}
#   Suggested Tests: (none detected)"
fi

# ---------------------------------------------------------------------------
# Inject template into the message file
# ---------------------------------------------------------------------------
# git pre-fills the file for a normal interactive commit as:
#   <empty line for subject>
#   <blank line>
#   # Please enter the commit message for your changes. Lines starting
#   # with '#' will be ignored, and an empty message aborts the commit.
#   ...
#
# Strategy: read the existing content, split on the first git comment block,
# insert our template between the user-editable area and git's comments.

existing=$(cat "$msg_file")

# Separate user-editable lines from git's own comment lines.
# Everything up to (not including) the first standalone git comment section.
# We look for the first line that matches "^# " as the boundary.
user_part=""
git_comments=""
found_git_comments=0

while IFS= read -r line; do
  if [[ "$found_git_comments" -eq 0 ]] && [[ "$line" =~ ^#[[:space:]] || "$line" == "#" ]]; then
    found_git_comments=1
  fi
  if [[ "$found_git_comments" -eq 0 ]]; then
    user_part="${user_part}${line}"$'\n'
  else
    git_comments="${git_comments}${line}"$'\n'
  fi
done <<< "$existing"

# Strip trailing newlines from user_part so we get clean spacing.
user_part="${user_part%$'\n'}"

# Compose: user area + blank line + our template + blank line + git comments.
{
  printf '%s\n' "$user_part"
  printf '%s\n' "$template_block"
  if [[ -n "$git_comments" ]]; then
    printf '\n'
    printf '%s' "$git_comments"
  fi
} > "$msg_file"

exit 0
